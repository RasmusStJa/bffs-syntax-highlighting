{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "before",
  "scopeName": "source.before",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.before",
          "match": "(?://|\\bCOMMENT\\b).*"
        },
        {
          "name": "comment.block.before",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.before",
          "match": "\\b(let|in|func|send|loop|stream|from|to)\\b"
        },
        {
          "name": "support.function.before",
          "match": "\\b(filter|map|merge|zip|unzip|scan|buffer|reduce|delay|mod|EQUAL|NOT|LESS|GREATER|AND|OR)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.symbol.before",
          "match": "(?:=>|\\+|-|\\*|/|=|\\\\|:|_)"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.numeric.integer.before",
          "match": "\\b[0-9]+\\b"
        },
        {
          "name": "constant.language.boolean.before",
          "match": "\\b(TRUE|FALSE)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.before",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.before",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.before",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_'?]*"
        }
      ]
    }
  }
}